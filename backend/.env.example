# 数据库配置
DB_HOST=your_database_host
DB_PORT=3306
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=your_database_name
DB_CONNECTION_LIMIT=10

# JWT配置
# ⚠️ 重要：请使用强随机密钥（至少64字符）
# 生成命令：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_at_least_64_characters_long_use_crypto_random_bytes
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=30d
# JWT黑名单使用数据库持久化（true）或内存存储（false）
JWT_BLACKLIST_PERSIST=true

# 服务器配置
PORT=3000
NODE_ENV=development

# 日志配置
LOG_LEVEL=info

# API配置
API_RATE_LIMIT=100
API_RATE_WINDOW_MS=900000

# 安全配置
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_key

# 缓存配置
CACHE_TTL=600
CACHE_MAX_KEYS=1000